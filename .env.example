# MonoFS Docker Compose Environment Variables
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Generate a 32-byte encryption key:
#   openssl rand -hex 32

# Required: 32-byte hex-encoded encryption key for packager archives.
# Used by fetchers (blob storage) and routers (archive creation during ingestion).
MONOFS_ENCRYPTION_KEY=

# Optional: Override Git version info
# GIT_VERSION=dev
# GIT_COMMIT=unknown
# BUILD_TIME=unknown
